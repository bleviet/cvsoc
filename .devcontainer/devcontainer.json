{
    "name": "cvsoc-quartus",
    "image": "cvsoc/quartus:23.1",
    "runArgs": ["--privileged", "--net=host"],
    "mounts": [
        "source=/dev/bus/usb,target=/dev/bus/usb,type=bind",
        "source=${localWorkspaceFolder}/common/docker/uname_shim.sh,target=/usr/local/bin/uname,type=bind,readonly"
    ],
    "customizations": {
        "vscode": {
            "extensions": ["ms-vscode.cpptools"]
        }
    }
}